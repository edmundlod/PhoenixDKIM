prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=@CMAKE_INSTALL_PREFIX@
libdir=@CMAKE_INSTALL_FULL_LIBDIR@
includedir=@CMAKE_INSTALL_FULL_INCLUDEDIR@/phoenixdkim

Name: PhoenixDKIM Library
Description: Library for performing DKIM signing and verification
URL: https://github.com/edmundlod/PhoenixDKIM
Version: @PACKAGE_VERSION@
Requires: openssl
Requires.private: libcrypto libssl@PHOENIXDKIM_PC_REQUIRES_PRIVATE@
Libs: -L${libdir} -lphoenixdkim
Libs.private:@PHOENIXDKIM_PC_PRIVATE_LIBS@
Cflags: -I${includedir}
