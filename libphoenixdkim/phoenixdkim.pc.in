# Process this file with autoconf to produce a pkg-config metadata file.

prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@/phoenixdkim

Name: PhoenixDKIM Library
Description: Library for performing DKIM signing and verification
URL: https://github.com/edmundlod/PhoenixDKIM
Version: @VERSION@
Libs: -L${libdir} @PTHREAD_CFLAGS@ -lphoenixdkim
Libs.private: @LIBPHOENIXDKIM_LIBS_PKG@ @PTHREAD_LIBS@
Cflags: -I${includedir} @PTHREAD_CFLAGS@

