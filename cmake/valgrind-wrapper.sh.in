#!/bin/sh
# phoenixdkim — Valgrind @VALGRIND_TOOL_NAME@ wrapper
#
# Auto-generated by cmake/Valgrind.cmake at cmake configure time.
# Do not edit; regenerated on every cmake run.
#
# Launched by miltertest Lua integration tests via $PHOENIXDKIM_BINPATH/phoenixdkim.
# The real daemon binary is exec'd under Valgrind so the daemon itself is
# instrumented, not just the miltertest process.

exec @VALGRIND_WRAPPER_EXEC_LINE@ "$@"
