/* build-config.h.cmake.in - Generated by CMake */

#ifndef _BUILD_CONFIG_H_
#define _BUILD_CONFIG_H_

/* Package version and feature string */
#define VERSION "@PROJECT_VERSION@"
#define PACKAGE_VERSION "@PROJECT_VERSION@"
#define LIBOPENDKIM_FEATURE_STRING "libopendkim @PROJECT_VERSION@:"

/* Numeric versioning for dkim.h */
#define OPENDKIM_LIB_VERSION_HEX @OPENDKIM_LIB_VERSION_HEX@

/* OpenSSL 3 is required; SHA256 is always present */
#define HAVE_SHA256 1
#define OPENSSL_VERSION_STR "@OPENSSL_VERSION@"

/* LMDB is required */
#define USE_MDB 1

/* Lua 5.4 scripting support (enabled with -DWITH_LUA=ON) */
#cmakedefine USE_LUA 1

/* libunbound (DNSSEC) support */
#cmakedefine USE_UNBOUND 1
#cmakedefine HAVE_UNBOUND_H 1

/* DNS resolver capability checks */
#cmakedefine HAVE_RES_NINIT 1
#cmakedefine HAVE_RES_SETSERVERS 1
#cmakedefine HAVE_RES_QUERY_LIBC 1
#cmakedefine HAVE_INET_PTON 1
#cmakedefine HAVE_INET_NTOP 1
#cmakedefine HAVE_GETADDRINFO 1

/* Path-resolution helpers (opendkim secure-file check) */
#cmakedefine HAVE_REALPATH 1
#cmakedefine HAVE_STRSEP 1

/* libcurl SMTP report delivery (enabled with -DWITH_CURL=ON) */
#cmakedefine HAVE_LIBCURL 1

/* Platform type/header availability */
#cmakedefine HAVE_ISO_LIMITS_ISO_H 1
#cmakedefine HAVE_USECONDS_T 1

/* Standard system headers */
#cmakedefine HAVE_LIMITS_H 1
#cmakedefine HAVE_STDBOOL_H 1
#cmakedefine HAVE_SYS_PARAM_H 1
#cmakedefine HAVE_SYS_FILE_H 1
#cmakedefine HAVE_PATHS_H 1
#cmakedefine HAVE_SYS_VFS_H 1
#cmakedefine HAVE_SYS_STATFS_H 1

/* strlcpy / strlcat header selection */
#cmakedefine USE_BSD_H 1
#cmakedefine USE_STRL_H 1

/* Sendmail path (used by opendkim daemon) */
#define SENDMAIL_PATH "@SENDMAIL_PATH@"

/* Default config file base path */
#define CONFIG_BASE "@CONFIG_BASE@"

/* smfi_version availability */
#cmakedefine HAVE_SMFI_VERSION 1
#cmakedefine HAVE_SMFI_OPENSOCKET 1
#cmakedefine HAVE_SMFI_PROGRESS   1
#cmakedefine HAVE_SMFI_SETSYMLIST 1

/* BSD socket structure length fields */
#cmakedefine HAVE_SUN_LEN  1
#cmakedefine HAVE_SIN_LEN  1
#cmakedefine HAVE_SIN6_LEN 1

/* st_node field in struct stat (BSD-specific) */
#cmakedefine HAVE_ST_NODE 1

#cmakedefine WITH_REDIS 1

#endif /* _BUILD_CONFIG_H_ */
