#cmakedefine HAVE_STDBOOL_H 1

/* strlcpy / strlcat header selection.
 * Set USE_BSD_H if bsd/string.h provides them; USE_STRL_H if strl.h does.
 * If neither is set the functions are available in the system libc. */
#cmakedefine USE_BSD_H 1
#cmakedefine USE_STRL_H 1

#endif /* _BUILD_CONFIG_H_ */
