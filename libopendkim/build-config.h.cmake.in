#ifndef _BUILD_CONFIG_H_
#define _BUILD_CONFIG_H_

/* OpenSSL 3 is required; SHA256 is always present */
#define HAVE_SHA256 1

/* LMDB is required */
#define USE_MDB 1

/* Promoted FFR features — no longer experimental per project scope */
#define _FFR_RESIGN 1
#define _FFR_IDENTITY_HEADER 1
#define _FFR_SENDER_MACRO 1

/* Lua 5.4 scripting support (enabled with -DWITH_LUA=ON) */
#cmakedefine USE_LUA 1

/* DNS resolver capability checks */
#cmakedefine HAVE_RES_NINIT 1
#cmakedefine HAVE_RES_SETSERVERS 1

/* Standard system headers */
